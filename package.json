{
  "name": "remotelink",
  "version": "1.0.9",
  "description": "RemoteLink - Remote Desktop Application for Windows",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --win --dir",
    "generate-icons": "node scripts/generate-icon.js"
  },
  "author": "RemoteLink",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.remotelink.app",
    "productName": "RemoteLink",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "neopelumi-hub",
        "repo": "remotelink"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "koffi": "^2.16.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
